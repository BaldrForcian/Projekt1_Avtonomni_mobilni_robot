<?xml version="1.0"?>
<robot name="diff_drive_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ===================== -->
  <!--     PROPERTIES        -->
  <!-- ===================== -->
  <xacro:property name="wheel_radius"    value="0.05035"/>
  <xacro:property name="wheel_width"     value="0.045"/>
  <xacro:property name="wheel_base"      value="0.29"/>
  <xacro:property name="base_length"     value="0.60"/>
  <xacro:property name="base_width"      value="0.40"/>
  <xacro:property name="base_height"     value="0.09"/>

  <!-- lidar offset from base_link center(offseti so od centra navidezne akse-sredisca motorjev) -->
  <xacro:property name="lidar_x"         value="0.255"/>
  <xacro:property name="lidar_y"         value="0.160"/>
  <xacro:property name="lidar_z"         value="0.09"/>

  <!-- ===================== -->
  <!--      BASE LINK        -->
  <!-- ===================== -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 3.14159"/>
  </joint>

  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0"
                           iyy="0.01" iyz="0"
                                       izz="0.01"/>
    </inertial>
  </link>

  <!-- ===================== -->
  <!--      LEFT WHEEL       -->
  <!-- ===================== -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="left_wheel"/>
    <origin xyz="0 ${wheel_base/2} 0" rpy="-${pi/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
                            iyy="0.001" iyz="0"
                                        izz="0.001"/>
    </inertial>
  </link>

  <!-- ===================== -->
  <!--      RIGHT WHEEL      -->
  <!-- ===================== -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="right_wheel"/>
    <origin xyz="0 ${-wheel_base/2} 0" rpy="-${pi/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
                            iyy="0.001" iyz="0"
                                        izz="0.001"/>
    </inertial>
  </link>

  <!-- ===================== -->
  <!--     LIDAR_MERGED      -->
  <!-- ===================== -->
  <joint name="laser_merged_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="laser"/>
    <origin xyz="${lidar_x} ${lidar_y} ${lidar_z}" rpy="0 0 3.14159"/>
  </joint>

  <link name="laser">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.04"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
                             iyy="0.0001" iyz="0"
                                          izz="0.0001"/>
    </inertial>
  </link>

  <!-- ===================== -->
  <!--     LIDAR_FRONT       -->
  <!-- ===================== -->
  <joint name="laser_front_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="laser_front"/>
    <origin xyz="${lidar_x} ${lidar_y} ${lidar_z}" rpy="0 0 3.14159"/>
  </joint>

  <link name="laser_front">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.04"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
                             iyy="0.0001" iyz="0"
                                          izz="0.0001"/>
    </inertial>
  </link>

  <!-- ===================== -->
  <!--     LIDAR_BACK       -->
  <!-- ===================== -->
  <joint name="laser_back_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="laser_back"/>
    <origin xyz="${-lidar_x} ${-lidar_y} ${lidar_z}" rpy="0 0 3.14159"/>
  </joint>

  <link name="laser_back">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.04"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
                             iyy="0.0001" iyz="0"
                                          izz="0.0001"/>
    </inertial>
  </link>

</robot>